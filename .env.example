# ─────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env et ajustez les valeurs selon votre environnement.
# Le fichier .env n'est jamais commité (voir .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Proxy HTTP (laisser vide si vous n'êtes pas derrière un proxy)
HTTP_PROXY=
HTTPS_PROXY=

# Fuseau horaire des conteneurs
TZ=Europe/Paris

# Mot de passe pour accéder à code-server (http://localhost:8443)
IDE_PASSWORD=zdev
