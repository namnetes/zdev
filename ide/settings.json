{
  // ==========================================
  // GESTION DU PROXY
  // ==========================================
  "http.noProxy": [
    "dev.prodinfo.fr.cly",
    "sysb.prodinfo.fr.cly",
    "sysr.prodinfo.fr.cly",
    "wd002app8520",
    "wd002app8523"
  ],
  "http.proxy": "http://10.242.16.144:8080",
  // ==========================================
  // INTERFACE & APPARENCE
  // ==========================================
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Catppuccin Frappé",
  "workbench.preferredLightColorTheme": "Default Light Modern",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "material-product-icons",
  "window.menuBarVisibility": "compact",
  // ==========================================
  // EDITEUR & COMPORTEMENT DE SAISIE
  // ==========================================
  "editor.fontFamily": "FiraCode Nerd Font, 'Courier New', monospace",
  "editor.fontSize": 15,
  "editor.fontWeight": "450",
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "blink",
  "editor.autoClosingBrackets": "always",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.inlayHints.enabled": "on",
  "editor.guides.indentation": true,
  "editor.linkedEditing": true,
  "editor.renderWhitespace": "boundary",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  // ==========================================
  // AUTOMATISATION, HYGIENE & DIAGNOSTICS
  // ==========================================
  "editor.formatOnSave": true,
  "files.autoSave": "onFocusChange",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // ==========================================
  // TERMINAL
  // ==========================================
  "terminal.integrated.fontFamily": "FiraCode Nerd Font, monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.suggest.insertTrailingSpace": true,
  "terminal.integrated.inheritEnv": true,
  // ==========================================
  // CONFIGURATION PAR LANGAGE
  // ==========================================
  "[python]": {
    "editor.rulers": [
      88
    ],
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never",
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },
  "[shellscript]": {
    "editor.rulers": [
      80
    ],
    "editor.tabSize": 2,
    "editor.wordWrap": "off",
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.formatOnSave": false
  },
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 120,
    "files.trimTrailingWhitespace": false
  },
  "[csv (semicolon)]": {
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[toml]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  // ==========================================
  // PYTHON (Pylance / ms-python)
  // ==========================================
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.indexing": true,
  // ==========================================
  // RUFF
  // ==========================================
  "ruff.configuration": "/home/zdev/ruff.toml",
  // ==========================================
  // GITHUB COPILOT — INSTRUCTIONS
  // ==========================================
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": "/home/zdev/.config/copilot/copilot-instructions.md"
    }
  ],
  "chat.instructionsFilesLocations": [
    ".github/instructions",
    "/home/zdev/.config/copilot/instructions"
  ],
  // ==========================================
  // ZOWE EXPLORER — désactive le credential manager (non supporté en conteneur sans keyring)
  // ==========================================
  "zowe.security.credentialManager": "",
  // ==========================================
  // YAML
  // ==========================================
  "yaml.schemaStore.enable": true,
  "yaml.format.enable": true,
  "yaml.customTags": [
    "!!python/name:pymdownx.superfences.fence_code_format scalar",
    "!!python/name:pymdownx.superfences.fence_div_format scalar",
    "!!python/name:material.extensions.emoji.twemoji scalar",
    "!!python/name:material.extensions.emoji.to_svg scalar"
  ],
  // ==========================================
  // IBM IDZEE
  // ==========================================
  "zopeneditor.JAVA_HOME": "/opt/java",
  "files.associations": {
    "**/*.COBOL*{,/*}": "cobol",
    "**/*.COB*{,/*}": "cobol",
    "**/*.COBCOPY*{,/*}": "cobol",
    "**/*.COPYBOOK*{,/*}": "cobol",
    "**/*.COPY*{,/*}": "cobol",
    "**/*.PL1*{,/*}": "pl1",
    "**/*.PLI*{,/*}": "pl1",
    "**/*.INC*{,/*}": "pl1",
    "**/*.INCLUDE*{,/*}": "pl1",
    "**/*.JCL*{,/*}": "jcl",
    "**/*.CNTL*{,/*}": "jcl",
    "**/*.PROC*{,/*}": "jcl",
    "**/*.ASM*{,/*}": "hlasm",
    "**/*.ASSEMBLE*{,/*}": "hlasm",
    "**/*.HLASM*{,/*}": "hlasm",
    "**/*.HLA*{,/*}": "hlasm",
    "**/*.MACLIB*{,/*}": "hlasm",
    "**/*.DBD*{,/*}": "hlasm",
    "**/*.MFS*{,/*}": "hlasm",
    "**/*.PCB*{,/*}": "hlasm",
    "**/*.EXEC*{,/*}": "rexx",
    "**/*.REXX*{,/*}": "rexx",
    "**/*.REXXINC*{,/*}": "rexx",
    "*.rex": "rexx"
  },
  "yaml.schemas": {
    "file:///home/zdev/.local/share/code-server/extensions/ibm.zopeneditor-6.5.0/resources/zapp-schema-1.9.0.json": [
      "zapp.yaml"
    ],
    "file:///home/zdev/.local/share/code-server/extensions/ibm.zopeneditor-6.5.0/resources/zcodeformat-schema-0.0.1.json": [
      "zcodeformat.yaml"
    ]
  },
  "json.schemas": [
    {
      "fileMatch": [
        "/zapp.json"
      ],
      "url": "file:///home/zdev/.local/share/code-server/extensions/ibm.zopeneditor-6.5.0/resources/zapp-schema-1.9.0.json"
    },
    {
      "fileMatch": [
        "/zcodeformat.json"
      ],
      "url": "file:///home/zdev/.local/share/code-server/extensions/ibm.zopeneditor-6.5.0/resources/zcodeformat-schema-0.0.1.json"
    }
  ]
}
